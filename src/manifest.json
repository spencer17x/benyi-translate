{
  "manifest_version": 3,
  "name": "本译 Benyi",
  "description": "本地运行、保留本意的隐私优先双语网页翻译。",
  "version": "0.1.0",
  "minimum_chrome_version": "138",
  "icons": {
    "16": "assets/icons/benyi-logo-16.png",
    "32": "assets/icons/benyi-logo-32.png",
    "48": "assets/icons/benyi-logo-48.png",
    "128": "assets/icons/benyi-logo-128.png"
  },
  "permissions": ["activeTab", "contextMenus", "offscreen", "scripting", "sidePanel"],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "使用本译翻译当前页",
    "default_icon": {
      "16": "assets/icons/benyi-logo-16.png",
      "32": "assets/icons/benyi-logo-32.png"
    }
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      }
    },
    "translate-page": {
      "suggested_key": {
        "default": "Ctrl+Shift+U",
        "mac": "Command+Shift+U"
      },
      "description": "翻译当前页面"
    },
    "toggle-pause-translation": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "Command+Shift+P"
      },
      "description": "暂停或继续翻译"
    },
    "cancel-translation": {
      "suggested_key": {
        "default": "Ctrl+Shift+X",
        "mac": "Command+Shift+X"
      },
      "description": "取消当前翻译"
    },
    "undo-translation": {
      "description": "撤销当前页面的全部译文"
    },
    "cycle-display-mode": {
      "description": "切换原文、双语和仅译文显示"
    },
    "translate-selection": {
      "description": "翻译选中文本"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
